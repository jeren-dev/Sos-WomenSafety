<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">


    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_animated_gradient" />


    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="1px"
        android:layout_height="1px"
        android:visibility="invisible" />


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:fadingEdgeLength="0dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <LinearLayout
                android:id="@+id/header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="48dp"
                android:paddingBottom="32dp"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:background="@drawable/glass_header">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Security Shield"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.5"
                    android:shadowColor="#000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Emergency Response System"
                    android:textColor="#E6FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp"
                    android:letterSpacing="0.3" />


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/status_indicator_bg"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/circle_green"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System Active • Location Tracking"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:id="@+id/mainContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingTop="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Emergency Actions"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"
                    android:letterSpacing="0.4" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">


                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card1"
                        style="@style/Widget.Material3.CardView.Elevated"
                        android:layout_width="0dp"
                        android:layout_height="200dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        app:cardBackgroundColor="#4DFFFFFF"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#30FFFFFF"
                        app:strokeWidth="1dp"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="20dp">


                            <FrameLayout
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:background="@drawable/icon_container_red">

                                <ImageView
                                    android:id="@+id/imvv1"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_alert_high"
                                    android:scaleType="centerCrop"
                                    android:layout_gravity="center"
                                    android:backgroundTint="#FFFFFF" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CAMERA ALERT"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="16dp"
                                android:letterSpacing="0.5" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Capture and Send"
                                android:textColor="#FFCCCB"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"
                                android:letterSpacing="0.3" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CRITICAL"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/red_tag_bg"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:layout_marginTop="12dp"
                                android:letterSpacing="0.5" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>


                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card2"
                        style="@style/Widget.Material3.CardView.Elevated"
                        android:layout_width="0dp"
                        android:layout_height="200dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        app:cardBackgroundColor="#4DFFFFFF"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#30FFFFFF"
                        app:strokeWidth="1dp"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="20dp">


                            <FrameLayout
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:background="@drawable/icon_container_orange">

                                <ImageView
                                    android:id="@+id/imvv2"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_alert_critical"
                                    android:scaleType="centerCrop"
                                    android:layout_gravity="center"
                                    android:backgroundTint="#FFFFFF" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EMAIL ALERT"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="16dp"
                                android:letterSpacing="0.5" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Send Location"
                                android:textColor="#FFE0B2"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"
                                android:letterSpacing="0.3" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="URGENT"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/orange_tag_bg"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:layout_marginTop="12dp"
                                android:letterSpacing="0.5" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card3"
                        style="@style/Widget.Material3.CardView.Elevated"
                        android:layout_width="0dp"
                        android:layout_height="200dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        app:cardBackgroundColor="#4DFFFFFF"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#30FFFFFF"
                        app:strokeWidth="1dp"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="20dp">


                            <FrameLayout
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:background="@drawable/icon_container_green">

                                <ImageView
                                    android:id="@+id/imvv3"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_alert_medium"
                                    android:scaleType="centerCrop"
                                    android:layout_gravity="center"
                                    android:backgroundTint="#FFFFFF" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SMS ALERT"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="16dp"
                                android:letterSpacing="0.5" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Text Contacts"
                                android:textColor="#C8E6C9"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"
                                android:letterSpacing="0.3" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACTIVE"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/green_tag_bg"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:layout_marginTop="12dp"
                                android:letterSpacing="0.5" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>


                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card4"
                        style="@style/Widget.Material3.CardView.Elevated"
                        android:layout_width="0dp"
                        android:layout_height="200dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        app:cardBackgroundColor="#4DFFFFFF"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#30FFFFFF"
                        app:strokeWidth="1dp"
                        android:foreground="?android:attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="20dp">


                            <FrameLayout
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:background="@drawable/icon_container_blue">

                                <ImageView
                                    android:id="@+id/imvv4"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_siren"
                                    android:scaleType="centerCrop"
                                    android:layout_gravity="center"
                                    android:backgroundTint="#FFFFFF" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SIREN SOUND"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="16dp"
                                android:letterSpacing="0.5" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Audio Alert"
                                android:textColor="#BBDEFB"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"
                                android:letterSpacing="0.3" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="READY"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/blue_tag_bg"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:layout_marginTop="12dp"
                                android:letterSpacing="0.5" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:id="@+id/buttonSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:paddingTop="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System Controls"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"
                    android:letterSpacing="0.4" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_panel"
                    android:padding="20dp">


                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/add"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginBottom="16dp"
                        android:text="Add Contact"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.3"
                        app:icon="@drawable/ic_add_contact"
                        app:iconTint="@color/white"
                        app:cornerRadius="16dp"
                        app:strokeColor="#4DFFFFFF"
                        app:strokeWidth="1dp"
                        app:backgroundTint="#20FFFFFF"
                        app:iconPadding="8dp"
                        app:iconGravity="textStart" />


                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/show"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginBottom="16dp"
                        android:text="Show Contacts"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.3"
                        app:icon="@drawable/ic_contacts"
                        app:iconTint="@color/white"
                        app:cornerRadius="16dp"
                        app:strokeColor="#4DFFFFFF"
                        app:strokeWidth="1dp"
                        app:backgroundTint="#20FFFFFF"
                        app:iconPadding="8dp"
                        app:iconGravity="textStart" />


                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/get"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:text="Track Location"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.3"
                        app:icon="@drawable/ic_location"
                        app:iconTint="@color/white"
                        app:cornerRadius="16dp"
                        app:strokeColor="#4DFFFFFF"
                        app:strokeWidth="1dp"
                        app:backgroundTint="#20FFFFFF"
                        app:iconPadding="8dp"
                        app:iconGravity="textStart" />



                </LinearLayout>
            </LinearLayout>


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <View
        android:layout_width="match_parent"
        android:layout_height="40dp"
        app:layout_anchor="@+id/view"
        app:layout_anchorGravity="bottom|center" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>